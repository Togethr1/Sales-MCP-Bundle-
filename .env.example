# Provider modes: fixture | live | disabled
SALES_MCP_SALESFORCE_MODE=fixture
SALES_MCP_GMAIL_MODE=fixture
SALES_MCP_APOLLO_MODE=fixture
SALES_MCP_CLAY_MODE=fixture
SALES_MCP_ZOOMINFO_MODE=fixture
SALES_MCP_CRUNCHBASE_MODE=fixture
SALES_MCP_BUILTWITH_MODE=fixture
SALES_MCP_SMARTLEAD_MODE=fixture
SALES_MCP_SERPER_MODE=fixture
SALES_MCP_APIFY_MODE=fixture
SALES_MCP_PITCHBOOK_MODE=fixture
SALES_MCP_TRIGIFY_MODE=fixture

# Salesforce and Gmail currently expect a pre-fetched OAuth 2.0 access token.
# Full OAuth flows are designed in docs/AUTH_DESIGN.md and are not yet implemented here.
# Legacy *_API_KEY names are still honored as compatibility fallbacks for these two providers.
SALES_MCP_SALESFORCE_ACCESS_TOKEN=
SALES_MCP_SALESFORCE_BASE_URL=
SALES_MCP_SALESFORCE_PAGE_SIZE=10
SALES_MCP_SALESFORCE_MAX_PAGES=3
SALES_MCP_SALESFORCE_TIMEOUT_MS=12000
SALES_MCP_SALESFORCE_RETRY_COUNT=2
SALES_MCP_GMAIL_ACCESS_TOKEN=
SALES_MCP_GMAIL_BASE_URL=https://gmail.googleapis.com/gmail/v1
SALES_MCP_GMAIL_PAGE_SIZE=10
SALES_MCP_GMAIL_MAX_PAGES=3
SALES_MCP_GMAIL_TIMEOUT_MS=8000
SALES_MCP_GMAIL_RETRY_COUNT=2

# Optional live adapter credentials and endpoints
SALES_MCP_APOLLO_API_KEY=
SALES_MCP_APOLLO_BASE_URL=https://api.apollo.io/api/v1
SALES_MCP_APOLLO_PAGE_SIZE=10
SALES_MCP_APOLLO_MAX_PAGES=3
SALES_MCP_APOLLO_TIMEOUT_MS=8000
SALES_MCP_APOLLO_RETRY_COUNT=2
SALES_MCP_CLAY_API_KEY=
SALES_MCP_ZOOMINFO_API_KEY=
SALES_MCP_CRUNCHBASE_API_KEY=
SALES_MCP_BUILTWITH_API_KEY=
SALES_MCP_SMARTLEAD_API_KEY=
SALES_MCP_SERPER_API_KEY=
SALES_MCP_SERPER_BASE_URL=https://google.serper.dev
SALES_MCP_SERPER_PAGE_SIZE=5
SALES_MCP_SERPER_MAX_PAGES=2
SALES_MCP_SERPER_TIMEOUT_MS=8000
SALES_MCP_SERPER_RETRY_COUNT=2
SALES_MCP_APIFY_API_KEY=
SALES_MCP_PITCHBOOK_API_KEY=
SALES_MCP_TRIGIFY_API_KEY=

# Optional outbound draft identity
SALES_MCP_OUTBOUND_SENDER_NAME=Your name
SALES_MCP_OUTBOUND_SENDER_TITLE=
SALES_MCP_OUTBOUND_SENDER_COMPANY=

# Optional heuristic scoring and resolution service URL
SALES_MCP_INTELLIGENCE_BASE_URL=http://127.0.0.1:8000

# Demo web override
VITE_INTELLIGENCE_BASE_URL=http://127.0.0.1:8000
